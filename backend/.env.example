# Copy to .env and fill in real values. Never commit .env.

# --- Admin auth (POST /admin/auth/login) ---
# Plaintext in .env; the server hashes it with bcrypt in memory at startup and never stores plaintext after load.
ADMIN_PASSWORD=your-admin-password

# Required for JWT signing in production (tests set a default in conftest).
JWT_SECRET=your-very-long-random-secret-value-at-least-32-bytes
# Keep short because logout revocation is in-memory for this single-server app.
JWT_EXPIRE_MINUTES=15
# Refresh token lifetime in days for silent access-token renewal.
ADMIN_REFRESH_EXPIRE_DAYS=7
# HTTPS production: set to true so the refresh cookie is not sent over plain HTTP.
# Local dev over http://localhost typically keeps this false.
ADMIN_REFRESH_COOKIE_SECURE=true

# --- Quiz / existing flags ---
QUIZ_SHOW_ANSWER_REVIEW=true

# --- CORS (comma-separated); omit to use dev defaults (localhost:3000 + 127.0.0.1:3000) ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
