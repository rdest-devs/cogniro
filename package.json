{
  "name": "cogniro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "validate": "pnpm -C frontend validate && uv run --project backend ruff check && uv run --project backend ruff format --check"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "frontend/**": "pnpm -C frontend exec prettier --write --ignore-unknown",
    "backend/**/*.py": [
      "uv run --project backend ruff check --fix",
      "uv run --project backend ruff format"
    ]
  }
}
