# Primary backend URL — used by the admin quiz client.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Fallback backend origin — used when NEXT_PUBLIC_API_BASE_URL is not set
# and for resolving quiz media assets.
# NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000

# Public path prefix for quiz media assets (must match backend MEDIA_PUBLIC_PREFIX).
# NEXT_PUBLIC_MEDIA_PUBLIC_PREFIX=/media/quiz-assets
